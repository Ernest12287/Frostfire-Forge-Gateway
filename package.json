{
  "name": "frostfire-gateway",
  "version": "1.0.0",
  "description": "Reverse proxy gateway for Frostfire Forge game servers",
  "module": "src/start.ts",
  "scripts": {
    "production": "bun --env-file=.env.production src/start.ts",
    "development": "bun --env-file=.env.development src/start.ts",
    "docker:dev:up": "docker-compose -f src/docker/docker-compose.dev.yml up -d",
    "docker:dev:down": "docker-compose -f src/docker/docker-compose.dev.yml down",
    "docker:dev:logs": "docker-compose -f src/docker/docker-compose.dev.yml logs -f",
    "docker:prod:up": "docker-compose -f src/docker/docker-compose.prod.yml up -d",
    "docker:prod:down": "docker-compose -f src/docker/docker-compose.prod.yml down",
    "docker:prod:logs": "docker-compose -f src/docker/docker-compose.prod.yml logs -f"
  },
  "keywords": [
    "gateway",
    "load-balancer",
    "game-server"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "@types/node": "^25.2.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "type": "module",
  "private": true,
  "dependencies": {
    "@types/nodemailer": "^7.0.9",
    "nodemailer": "^8.0.1"
  }
}
